# .env.example

# Server Configuration
PORT=3000
NODE_ENV=development

# Clever Cloud MySQL Database (auto-injected in production)
MYSQL_ADDON_HOST=
MYSQL_ADDON_USER=
MYSQL_ADDON_PASSWORD=
MYSQL_ADDON_DB=
MYSQL_ADDON_PORT=3306

# Local Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=nigeria_bece_db
DB_PORT=3306

# Redis (optional — app degrades gracefully without it)
REDIS_URL=
REDISCLOUD_URL=

# Session Secret — REQUIRED in production
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# Paystack API Keys
PAYSTACK_SECRET_KEY=sk_test_your_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Nigeria BECE Portal <no-reply@bece.gov.ng>"
ADMIN_EMAIL=admin@bece.gov.ng

# SMS Configuration (Termii)
SMS_API_KEY=your_sms_api_key
SMS_SENDER=BECE-NG
SMS_BASE_URL=https://api.ng.termii.com/api/sms/send

# App URLs
BASE_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Super Admin — used by initializeSuperAdmins() on first startup
SUPER_ADMIN_EMAIL=superadmin@bece.gov.ng
SUPER_ADMIN_PASSWORD=change-this-strong-password

# Logging
LOG_LEVEL=debug
# LOG_FILE=/var/log/bece/error.log  # production only