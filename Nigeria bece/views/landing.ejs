<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nigeria BECE - Home</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <header>
    <img src="/images/logo.svg" alt="Logo" height="50" />
    <nav>
      <a href="/">Home</a>
      <a href="/auth/login">Login</a>
      <a href="/auth/register">Register Now</a>
    </nav>
  </header>

  <main>
    <section class="hero">
      <h1>Welcome to Nigeria BECE</h1>
      <p>Prepare and manage your BECE exams easily.</p>
      <div class="actions">
        <a href="/auth/register" class="btn btn-primary">Register Now</a>
        <a href="/auth/login" class="btn btn-secondary">Login with PIN</a>
      </div>
    </section>

    <section class="blog">
      <h2>Latest Updates</h2>
      <% if (updates && updates.length > 0) { %>
        <% updates.forEach(update => { %>
          <article>
            <h3><%= update.title %></h3>
            <p><%= update.content %></p>
          </article>
        <% }) %>
      <% } else { %>
        <p>No updates yet. Check back soon.</p>
      <% } %>
    </section>
  </main>

  <footer>
    <p>&copy; <%= new Date().getFullYear() %> Nigeria BECE</p>
  </footer>
</body>
</html>
