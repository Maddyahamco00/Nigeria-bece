<header class="bg-blue-800 text-white p-4 flex justify-between items-center">
  <div class="flex items-center">
    <img src="/images/logo.svg" alt="Logo" class="h-10 mr-4">
    <h1 class="text-xl font-bold">Nigeria BECE Admin</h1>
  </div>
  <nav>
    <% if (user) { %>
      <a href="/admin/profile" class="mr-4 hover:underline">Profile</a>
      <a href="/auth/logout" class="hover:underline">Logout</a>
    <% } else { %>
      <a href="/auth/login" class="mr-4 hover:underline">Login</a>
      <a href="/auth/register" class="hover:underline">Register</a>
    <% } %>
  </nav>
</header>