
<!-- views/admin/schools.ejs-->
 <%- include('../partials/head', { title: 'Schools' }) %>
<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="ml-64 p-6">
  <h2 class="text-2xl font-bold mb-6">Manage Schools</h2>
  <div class="bg-white p-6 rounded-lg shadow">
    <table class="w-full table-auto">
      <thead>
        <tr class="bg-gray-200">
          <th class="p-2">Name</th>
          <th class="p-2">State</th>
          <th class="p-2">Students</th>
          <th class="p-2">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% schools.forEach(school => { %>
          <tr>
            <td class="p-2"><%= school.name %></td>
            <td class="p-2"><%= school.state %></td>
            <td class="p-2"><%= school.studentCount %></td>
            <td class="p-2">
              <a href="/admin/schools/edit/<%= school.id %>" class="text-blue-600 hover:underline">Edit</a>
              <a href="/admin/schools/delete/<%= school.id %>" class="text-red-600 hover:underline ml-2">Delete</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</main>

<%- include('../partials/footer') %>