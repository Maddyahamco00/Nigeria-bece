<%- include('../partials/head', { title: 'Dashboard' }) %>
<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="ml-64 p-6">
  <h2 class="text-2xl font-bold mb-6">Admin Dashboard</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white p-6 rounded-lg shadow">
      <h3 class="text-lg font-semibold">Total Students</h3>
      <p class="text-3xl font-bold"><%= stats.students || 0 %></p>
    </div>
    <div class="bg-white p-6 rounded-lg shadow">
      <h3 class="text-lg font-semibold">Total Schools</h3>
      <p class="text-3xl font-bold"><%= stats.schools || 0 %></p>
    </div>
    <div class="bg-white p-6 rounded-lg shadow">
      <h3 class="text-lg font-semibold">Total Payments</h3>
      <p class="text-3xl font-bold"><%= stats.payments || 0 %></p>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>