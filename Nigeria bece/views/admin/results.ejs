<%- include('../partials/head', { title: 'Results' }) %>
<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="ml-64 p-6">
  <h2 class="text-2xl font-bold mb-6">Manage Results</h2>
  <div class="bg-white p-6 rounded-lg shadow">
    <table class="w-full table-auto">
      <thead>
        <tr class="bg-gray-200">
          <th class="p-2">Student</th>
          <th class="p-2">Subject</th>
          <th class="p-2">Score</th>
          <th class="p-2">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% results.forEach(result => { %>
          <tr>
            <td class="p-2"><%= result.studentName %></td>
            <td class="p-2"><%= result.subject %></td>
            <td class="p-2"><%= result.score %></td>
            <td class="p-2">
              <a href="/admin/results/edit/<%= result.id %>" class="text-blue-600 hover:underline">Edit</a>
              <a href="/admin/results/delete/<%= result.id %>" class="text-red-600 hover:underline ml-2">Delete</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</main>

<%- include('../partials/footer') %>