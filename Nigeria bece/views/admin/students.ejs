<!-- views/admin/student.ejs-->
 <%- include('../partials/head', { title: 'Students' }) %>
<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="ml-64 p-6">
  <h2 class="text-2xl font-bold mb-6">Manage Students</h2>
  <div class="bg-white p-6 rounded-lg shadow">
    <form action="/admin/students" method="POST" class="mb-6">
  <div class="flex space-x-4">
    <input type="text" name="name" placeholder="Student Name" required class="border p-2 rounded w-1/3">
    <input type="email" name="email" placeholder="Email" required class="border p-2 rounded w-1/3">
    <select name="schoolId" required class="border p-2 rounded w-1/3">
      <% schools.forEach(school => { %>
        <option value="<%= school.id %>"><%= school.name %></option>
      <% }) %>
    </select>
    <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">Register</button>
  </div>
</form>

    <table class="w-full table-auto">
      <thead>
        <tr class="bg-gray-200">
          <th class="p-2">Name</th>
          <th class="p-2">Reg Number</th>
          <th class="p-2">School</th>
          <th class="p-2">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% students.forEach(student => { %>
          <tr>
            <td class="p-2"><%= student.name %></td>
            <td class="p-2"><%= student.regNumber %></td>
            <td class="p-2"><%= student.schoolName %></td>
            <td class="p-2">
              <a href="/admin/students/edit/<%= student.id %>" class="text-blue-600 hover:underline">Edit</a>
              <a href="/admin/students/delete/<%= student.id %>" class="text-red-600 hover:underline ml-2">Delete</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</main>

<%- include('../partials/footer') %>